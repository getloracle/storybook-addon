{
  "name": "@loracle-js/storybook-addon",
  "version": "0.1.1",
  "description": "AI-powered component development inside Storybook",
  "author": "Loracle <team@getloracle.com>",
  "license": "Apache-2.0",
  "homepage": "https://getloracle.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/getloracle/storybook-addon.git"
  },
  "bugs": {
    "url": "https://github.com/getloracle/storybook-addon/issues"
  },
  "keywords": [
    "storybook-addon",
    "storybook",
    "ai",
    "component-development",
    "loracle",
    "opencode"
  ],
  "storybook": {
    "displayName": "Loracle",
    "supportedFrameworks": [
      "react"
    ],
    "icon": "https://getloracle.com/loracle-icon.png"
  },
  "type": "module",
  "main": "dist/preset.js",
  "exports": {
    ".": "./dist/preset.js",
    "./preset": "./dist/preset.js",
    "./manager": "./dist/manager.js",
    "./preview": "./dist/preview.js",
    "./package.json": "./package.json"
  },
  "bundler": {
    "nodeEntries": [
      "./dist/preset.js"
    ],
    "managerEntries": [
      "./dist/manager.js"
    ],
    "previewEntries": [
      "./dist/preview.js"
    ]
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "opencode-ai"
    ]
  },
  "scripts": {
    "build": "rm -rf dist && tsup",
    "dev": "tsup --watch",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.2.24",
    "host-validation-middleware": "^0.1.2",
    "opencode-ai": "^1.3.6"
  },
  "peerDependencies": {
    "storybook": "^8.0.0 || ^9.0.0"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.17",
    "@storybook/components": "^8.6.17",
    "@storybook/manager-api": "^8.6.17",
    "@storybook/react": "^8.6.17",
    "@storybook/react-vite": "^8.6.17",
    "@storybook/theming": "^8.6.17",
    "@storybook/types": "^8.6.17",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "puppeteer": "^24.40.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "storybook": "^8.6.17",
    "tsup": "^8.0.0",
    "typescript": "^5.8.2",
    "vite": "^5.4.0"
  }
}
